---
import Pin from '../components/icons/Pin.astro';
import Envelope from '../components/icons/Envelope.astro';
import { personalInfo, languages, techSkills, passions, professionalDescription } from '../data/cv-data';
---

<aside class="w-full lg:w-80 xl:w-96 bg-slate-900 text-slate-300 p-8 shrink-0">
    <div class="space-y-8">
      <div>
        <h1 class="text-3xl font-bold text-white">{personalInfo.name}</h1>
        <div class="mt-2">
          {personalInfo.highlights.map((highlight: string) => <p class="text-blue-400 font-mono">{highlight}</p>)}
        </div>

        <div class="mt-4 space-y-1 text-sm">
          <div class="flex items-center gap-2">
              <Pin class="size-5 text-blue-400" />
              <span>{personalInfo.location}</span>
          </div>
          <div class="flex items-center gap-2">
              <Envelope class="size-5 text-blue-400" />
              <span>{personalInfo.email}</span>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-xs uppercase tracking-widest text-slate-500 font-bold mb-3">Professional Summary</h2>
      
        <p class="text-sm leading-relaxed">
          {professionalDescription}
        </p>
      </div>

      <div class="space-y-6">

        <div class="mt-8 space-y-4">
          <h2 class="text-xs uppercase tracking-widest text-slate-500 font-bold mb-4">Languages</h2>
          <div class="grid grid-cols-2 gap-x-12 gap-y-4">
            {languages.map((lang) => (
              <div class="flex items-center justify-between group border-b border-slate-800/50 pb-2">
                <div class="flex flex-col">
                  <span class="text-sm font-semibold text-slate-200 group-hover:text-blue-400 transition-colors">
                    {lang.name}
                  </span>
                </div>
                <div class="flex flex-col items-end">
                  <span class="text-[10px] font-black uppercase tracking-tighter text-blue-500/90">
                    {lang.label}
                  </span>
                  {/* Optional: Tiny CEFR code for that "European Dual-Degree" polish */}
                  <span class="text-[12px] text-slate-600 font-medium">
                    {lang.level === 6 ? 'C2' : lang.level === 5 ? 'C1' : 'B2'}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="mt-8 space-y-4">
          <h2 class="text-xs uppercase tracking-widest text-slate-500 font-bold mb-4">Programming & Tech Skills</h2>
          <div class="grid grid-cols-2 gap-x-8 gap-y-6">
            {techSkills.map((skill) => (
              <div class="group border-b border-slate-800/40 pb-2">
                <div class="flex justify-between items-end mb-0.5">
                  <span class="text-xs font-bold text-slate-100 group-hover:text-blue-400 transition-colors uppercase tracking-tight">
                    {skill.name}
                  </span>
                  <span class="text-[10px] font-black text-blue-500/90 uppercase tracking-tighter">
                    {skill.level}
                  </span>
                </div>
                {/* The "Code Comment" Focus
                <p class="text-[10px] font-mono text-slate-500 leading-tight">
                  <span class="text-slate-600">/*</span> {skill.focus} <span class="text-slate-600"></span>
                </p>
                */}
                <p class="text-[10px] text-slate-500 leading-tight italic">
                  {skill.focus}
                </p>
              </div>
            ))}
          </div>
        </div>
            
            <div>
              <h2 class="text-xs uppercase tracking-widest text-slate-500 font-bold mb-3">Passions</h2>
              <div class="flex flex-wrap gap-2">
                {passions.map(l => <span class="bg-blue-900/30 text-blue-300 px-2 py-1 rounded text-xs border border-blue-800/50">{l}</span>)}
              </div>
            </div>
      </div>
    </div>
  </aside>