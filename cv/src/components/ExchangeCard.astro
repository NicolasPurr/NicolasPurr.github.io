---
// src/components/ExchangeCard.astro
import AcademicHat from './icons/AcademicHat.astro';

interface Props {
  exchange: any;
  index: number;
}

const { exchange, index } = Astro.props;
const exchangeToggleId = `exchange-toggle-${index}`;
---

<div class="mt-4 p-4 bg-slate-50 rounded-lg border-l-4 border-blue-500 relative">
  <span class="text-[10px] font-bold text-blue-600 uppercase italic">Exchange Program</span>
  <div>
    <span class="text-sm font-bold text-slate-800">{exchange.institution}</span>
    <span class="ml-2 text-slate-400 text-[10px] font-mono">{exchange.location}</span>
  </div>
  <p class="text-slate-400 text-[10px] font-mono mb-2">{exchange.duration}</p>

  {exchange.description && (
    <p class="text-xs text-slate-600 leading-relaxed">
      {exchange.description}
    </p>
  )}



  {exchange.mainGrades.length > 0 && (
    <div class="relative inline-block">
      <input type="checkbox" id={exchangeToggleId} class="peer hidden" />
      <label 
        for={exchangeToggleId} 
        class="inline-flex items-center gap-2 px-2 py-1 rounded border border-slate-200 bg-white text-[10px] font-bold text-slate-500 cursor-pointer hover:bg-blue-50 hover:text-blue-600 transition-all peer-checked:bg-blue-600 peer-checked:text-white shadow-sm"
      >
         <AcademicHat class="size-3" />
         Exchange Grades
      </label>

      {/* pop-up */}
      <div class="absolute bottom-full left-0 mb-3 w-64 p-4 bg-white rounded-xl shadow-2xl border border-slate-100 invisible opacity-0 translate-y-2 pointer-events-none peer-checked:visible peer-checked:opacity-100 peer-checked:translate-y-0 peer-checked:pointer-events-auto transition-all duration-200 z-50">
        <div class="flex justify-between items-center mb-3">
          <h4 class="text-[9px] uppercase font-bold text-slate-400 tracking-widest">Exchange Transcript</h4>
          <label for={exchangeToggleId} class="text-slate-300 hover:text-slate-500 cursor-pointer text-xs">✕</label>
        </div>
        <ul class="space-y-2">
          {exchange.mainGrades.map((g: any) => (
            <li class="flex justify-between text-[10px] border-b border-slate-50 pb-1 last:border-0">
              <a href={g.curriculumUrl} target="_blank" class="text-slate-600 hover:text-blue-600 transition-colors">
                {g.name}
              </a>
              <span class="font-mono font-bold text-blue-600">{g.score}</span>
            </li>
          ))}
        </ul>
        <div class="absolute top-full left-4 -mt-1 border-8 border-transparent border-t-white"></div>
      </div>
    </div>
  )}
</div>