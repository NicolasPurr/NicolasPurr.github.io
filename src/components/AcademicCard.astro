---
// src/components/AcademicCard.astro
import { academicData } from '../data/cv-data';
import AcademicHat from './icons/AcademicHat.astro';
import ExchangeCard from './ExchangeCard.astro';
---
<section class="space-y-8">
    <div class="flex items-center gap-4 mb-6">
      <h2 class="text-2xl font-black uppercase tracking-tighter">Academic</h2>
      <div class="h-0.5 flex-1 bg-slate-200"></div>
    </div>

    {academicData.map((edu, index) => {
        const toggleId = `toggle-${index}`;
      
        const statusStyles: { [key: string]: string } = {
          ongoing: "border-blue-600 [background:conic-gradient(theme(colors.blue.500)_180deg,transparent_0)] rotate-[-45deg]",
          completed: "bg-blue-500 border-blue-600",
          resigned: "bg-red-600 border-red-700 shadow-sm",
        };
      
        const circleColor = statusStyles[edu.status] || "bg-white border-slate-300";
      
        return (
          <div class="group relative pl-8 border-l-2 border-slate-200 mb-10 last:mb-0">
            {/* circle */}
            <div class={`absolute -left-2.25 top-1.5 w-4 h-4 rounded-full border-2 transition-all duration-300 ${circleColor} group-hover:scale-110`}></div>
            
            {/* header */}
            <h3 class={`text-lg font-bold leading-tight transition-colors ${edu.status === 'resigned' ? 'text-slate-400 decoration-slate-300' : 'text-slate-900'}`}>
                <span class={edu.status === 'resigned' ? 'line-through decoration-slate-300' : ''}>
                    {edu.uni}
                </span>

                {edu.status === 'resigned' && (
                    <span class="
                    text-[9px] uppercase tracking-tighter font-black
                    ml-2 px-2 py-0.5 rounded-full
                    bg-red-50 text-red-500 border border-red-100
                    shadow-[0_0_10px_rgba(239,68,68,0.1)]
                    italic select-none
                    ">
                    Discontinued
                    </span>
                )}
            </h3>
            
            <p class="text-blue-600 font-medium text-sm">{edu.degree}</p>
            <p class="text-slate-400 text-xs font-mono mt-1">{edu.duration}</p>
            
            <p class={`mt-3 text-sm leading-relaxed ${edu.status === 'resigned' ? 'text-slate-500 italic' : 'text-slate-700'}`}>
              {edu.description}
            </p>
      
            {/* exchange card */}
            {edu.exchange && <ExchangeCard exchange={edu.exchange} index={index} />}
      
            {/* grades button */}
            {edu.status != 'resigned' && (
            <div class="relative inline-block mt-4">
                <input type="checkbox" id={toggleId} class="peer hidden" />
        
                <label for={toggleId} class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md bg-white border border-slate-200 text-xs font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all select-none peer-checked:bg-blue-600 peer-checked:text-white peer-checked:hover:text-blue-600 peer-checked:border-blue-600 shadow-sm">
                    <AcademicHat class={`size-4 ${edu.mainGrades.length > 0 ? 'text-blue-500' : 'text-slate-300'}`} />
                    View Relevant Grades
                </label>
        
                {/* Pop-up */}
                <div class="absolute bottom-full left-0 mb-3 w-72 p-4 bg-white rounded-xl shadow-2xl border border-slate-100 invisible opacity-0 translate-y-2 pointer-events-none peer-checked:visible peer-checked:opacity-100 peer-checked:translate-y-0 peer-checked:pointer-events-auto transition-all duration-200 z-60">
                    <div class="flex justify-between items-center mb-3">
                    <h4 class="text-[10px] uppercase font-bold text-slate-400 tracking-widest">Transcript</h4>
                    <label for={toggleId} class="text-slate-300 hover:text-slate-500 cursor-pointer text-xs">X</label>
                    </div>
                    <ul class="space-y-2">
                    {edu.mainGrades.map((g) => (
                        <li class="flex justify-between text-[11px] border-b border-slate-50 pb-1 last:border-0">
                        <a href={g.curriculumUrl} target="_blank" class="text-slate-600 hover:text-blue-600 transition-colors">{g.name}</a>
                        <span class="font-mono font-bold text-blue-600">{g.score}</span>
                        </li>
                    ))}
                    </ul>
                    <div class="absolute top-full left-6 -mt-1 border-8 border-transparent border-t-white"></div>
                </div>
            </div>
            )}
          </div>
        );
      })}
</section>