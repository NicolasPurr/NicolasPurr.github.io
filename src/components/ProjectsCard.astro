---
import BulletPoint from './icons/BulletPointPink.astro';
import { projectsData } from '../data/cv-data.ts';

---
<section class="space-y-8">
  <div class="flex items-center gap-4 mb-6">
    <h2 class="text-2xl font-black uppercase tracking-tighter">Projects</h2>
    <div class="h-0.5 flex-1 bg-slate-200"></div>
  </div>

  {projectsData.map((project) => {
    const statusStyles: { [key: string]: string } = {
      ongoing: "bg-pink-700 border-pink-800 [background:conic-gradient(theme(colors.pink.700)_180deg,transparent_0)] rotate-[-45deg]",
      completed: "bg-pink-700 border-pink-800",
    };

    const circleColor = statusStyles[project.status] || "bg-white border-slate-300";

    return (
      <div class="group relative pl-8 border-l-2 border-slate-200">
        <!-- Timeline Dot -->
        <div class={`absolute -left-2.25 top-1.5 w-4 h-4 rounded-full border-2 transition-all duration-300 ${circleColor} group-hover:scale-110`}></div>
        
        <!-- Header Info -->
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="text-lg font-bold leading-tight">{project.name}</h3>
            <p class="text-pink-700 font-medium text-sm">{project.type}</p>
          </div>
          
          <!-- GitHub / Page Link Button -->
          {project.link && (
            <a 
              href={project.link} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="px-3 py-1 text-xs font-semibold text-slate-600 bg-white border border-slate-200 rounded shadow-sm hover:bg-slate-50 hover:text-pink-700 hover:border-pink-300 transition-colors duration-200 whitespace-nowrap"
          >
            {project.linkLabel} →
          </a>
          )}
        </div>
        
        <!-- Skill & Language Tags -->
        <div class="flex flex-wrap gap-1.5 mt-2">
          {project.tags.map(tag => (
            <span class="px-2 py-0.5 text-[10px] font-bold tracking-wide uppercase bg-pink-50 text-pink-800 border border-pink-200 rounded-sm">
              {tag}
            </span>
          ))}
        </div>
        
        <!-- Short Descriptions -->
        <ul class="mt-3 space-y-2">
          {project.description.map(bullet => (
            <li class="flex gap-3 text-sm text-slate-600 leading-relaxed">
              <div class="mt-[5px] shrink-0 transition-all duration-300 group-hover:translate-x-1 group-hover:text-pink-600">
                <BulletPoint />
              </div>
              <span>{bullet}</span>
            </li>
          ))}
        </ul>
      </div>
    );
  })}
</section>